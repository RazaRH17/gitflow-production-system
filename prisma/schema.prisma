// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon requires directUrl for migrations via CLI
  directUrl = env("DIRECT_DATABASE_URL")
}

model GitFile {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  content        String   @db.Text
  current_branch Branch   @default(dev)
  locked_by      String?  // null = unlocked; value = "User A" | "User B" | "User C"
  sha            String?  // GitHub blob SHA required for update operations
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("git_files")
}

enum Branch {
  dev
  staging
  main
}
